<div class="search-container col-lg-12">
    <%= react_component(
      'AdvancedSearch/components/Container',
      {
        fieldUuid: field.uuid,
        defaultValues: value,
        childComponent: 'AdvancedSearch/components/Reference',
        isGloballyFirst: (i == 0),
        childProps: {
          catalog: field.catalog.slug,
          itemType: field.related_item_type.slug,
          locale: I18n.locale,
          selectCondition: field.search_conditions_as_hash,
          fieldConditionData: field.search_field_conditions_as_hash,
        }
      },
      {
        class: "mb-3"
      }
    ) %>
</div>
